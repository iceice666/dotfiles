{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary_dark": "{{color.dark.primary}}",
    "primary_light": "{{color.light.primary}}",
    "secondary_dark": "{{color.dark.secondary}}",
    "secondary_light": "{{color.light.secondary}}",
    "tertiary_dark": "{{color.dark.tertiary}}",
    "tertiary_light": "{{color.light.tertiary}}",
    "error_dark": "{{color.dark.error}}",
    "error_light": "{{color.light.error}}",
    "warning_dark": "{{base16.dark.base0A}}",
    "warning_light": "{{base16.light.base0A}}",
    "text_dark": "{{color.dark.on_surface}}",
    "text_light": "{{color.light.on_surface}}",
    "text_muted_dark": "{{color.dark.on_surface_variant}}",
    "text_muted_light": "{{color.light.on_surface_variant}}",
    "background_dark": "{{color.dark.background}}",
    "background_light": "{{color.light.background}}",
    "surface_low_dark": "{{color.dark.surface_container_low}}",
    "surface_low_light": "{{color.light.surface_container_low}}",
    "surface_panel_dark": "{{color.dark.surface_container}}",
    "surface_panel_light": "{{color.light.surface_container}}",
    "surface_element_dark": "{{color.dark.surface_container_high}}",
    "surface_element_light": "{{color.light.surface_container_high}}",
    "border_dark": "{{color.dark.outline_variant}}",
    "border_light": "{{color.light.outline_variant}}",
    "border_active_dark": "{{color.dark.primary}}",
    "border_active_light": "{{color.light.primary}}",
    "border_subtle_dark": "{{ color.dark.outline_variant | mix(color.dark.surface_container, 0.55) | to_hex() }}",
    "border_subtle_light": "{{ color.light.outline_variant | mix(color.light.surface_container, 0.55) | to_hex() }}",
    "created_dark": "{{color.dark.tertiary}}",
    "created_light": "{{color.light.tertiary}}",
    "created_bg_dark": "{{color.dark.tertiary_container}}",
    "created_bg_light": "{{color.light.tertiary_container}}",
    "deleted_dark": "{{color.dark.error}}",
    "deleted_light": "{{color.light.error}}",
    "deleted_bg_dark": "{{color.dark.error_container}}",
    "deleted_bg_light": "{{color.light.error_container}}",
    "modified_dark": "{{color.dark.secondary}}",
    "modified_light": "{{color.light.secondary}}",
    "syntax_comment_dark": "{{seed.color | to_oklch() | rotate(170) | chroma(0.08) | lightness(0.66) | readable(color.dark.surface_container_low, 3.2) | to_hex()}}",
    "syntax_comment_light": "{{seed.color | to_oklch() | rotate(170) | chroma(0.08) | lightness(0.56) | readable(color.light.surface_container_low, 3.2) | to_hex()}}",
    "syntax_emphasis_dark": "{{seed.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_emphasis_light": "{{seed.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.5) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_function_dark": "{{seed.color | to_oklch() | rotate(-80) | chroma(0.12) | lightness(0.72) | readable(color.dark.surface_container_low, 3.2) | to_hex()}}",
    "syntax_function_light": "{{seed.color | to_oklch() | rotate(-80) | chroma(0.12) | lightness(0.5) | readable(color.light.surface_container_low, 3.2) | to_hex()}}",
    "syntax_keyword_dark": "{{seed.color | to_oklch() | rotate(-52) | chroma(0.16) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_keyword_light": "{{seed.color | to_oklch() | rotate(-52) | chroma(0.16) | lightness(0.44) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_number_dark": "{{seed.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_number_light": "{{seed.color | to_oklch() | chroma(0.18) | lightness(0.46) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_operator_dark": "{{color.dark.on_surface}}",
    "syntax_operator_light": "{{color.light.on_surface}}",
    "syntax_punctuation_dark": "{{color.dark.on_surface_variant}}",
    "syntax_punctuation_light": "{{color.light.on_surface_variant}}",
    "syntax_string_dark": "{{seed.color | to_oklch() | rotate(145) | chroma(0.2) | lightness(0.79) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_string_light": "{{seed.color | to_oklch() | rotate(145) | chroma(0.2) | lightness(0.44) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_type_dark": "{{seed.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_type_light": "{{seed.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.42) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_variable_dark": "{{seed.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_variable_light": "{{seed.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.42) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_title_dark": "{{seed.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_title_light": "{{seed.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.5) | readable(color.light.surface_container_low, 4.5) | to_hex()}}",
    "syntax_link_dark": "{{seed.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.84) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
    "syntax_link_light": "{{seed.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.38) | readable(color.light.surface_container_low, 4.5) | to_hex()}}"
  },
  "theme": {
    "primary": { "dark": "primary_dark", "light": "primary_light" },
    "secondary": { "dark": "secondary_dark", "light": "secondary_light" },
    "accent": { "dark": "tertiary_dark", "light": "tertiary_light" },
    "error": { "dark": "error_dark", "light": "error_light" },
    "warning": { "dark": "warning_dark", "light": "warning_light" },
    "success": { "dark": "created_dark", "light": "created_light" },
    "info": { "dark": "primary_dark", "light": "primary_light" },
    "text": { "dark": "text_dark", "light": "text_light" },
    "textMuted": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "background": { "dark": "background_dark", "light": "background_light" },
    "backgroundPanel": { "dark": "surface_panel_dark", "light": "surface_panel_light" },
    "backgroundElement": { "dark": "surface_element_dark", "light": "surface_element_light" },
    "border": { "dark": "border_dark", "light": "border_light" },
    "borderActive": { "dark": "border_active_dark", "light": "border_active_light" },
    "borderSubtle": { "dark": "border_subtle_dark", "light": "border_subtle_light" },
    "diffAdded": { "dark": "created_dark", "light": "created_light" },
    "diffRemoved": { "dark": "deleted_dark", "light": "deleted_light" },
    "diffContext": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "diffHunkHeader": { "dark": "modified_dark", "light": "modified_light" },
    "diffHighlightAdded": { "dark": "created_dark", "light": "created_light" },
    "diffHighlightRemoved": { "dark": "deleted_dark", "light": "deleted_light" },
    "diffAddedBg": { "dark": "created_bg_dark", "light": "created_bg_light" },
    "diffRemovedBg": { "dark": "deleted_bg_dark", "light": "deleted_bg_light" },
    "diffContextBg": { "dark": "surface_low_dark", "light": "surface_low_light" },
    "diffLineNumber": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "diffAddedLineNumberBg": { "dark": "created_bg_dark", "light": "created_bg_light" },
    "diffRemovedLineNumberBg": { "dark": "deleted_bg_dark", "light": "deleted_bg_light" },
    "markdownText": { "dark": "text_dark", "light": "text_light" },
    "markdownHeading": { "dark": "syntax_title_dark", "light": "syntax_title_light" },
    "markdownLink": { "dark": "syntax_link_dark", "light": "syntax_link_light" },
    "markdownLinkText": { "dark": "primary_dark", "light": "primary_light" },
    "markdownCode": { "dark": "syntax_string_dark", "light": "syntax_string_light" },
    "markdownBlockQuote": { "dark": "text_muted_dark", "light": "text_muted_light" },
    "markdownEmph": { "dark": "syntax_emphasis_dark", "light": "syntax_emphasis_light" },
    "markdownStrong": { "dark": "syntax_title_dark", "light": "syntax_title_light" },
    "markdownHorizontalRule": { "dark": "border_subtle_dark", "light": "border_subtle_light" },
    "markdownListItem": { "dark": "primary_dark", "light": "primary_light" },
    "markdownListEnumeration": { "dark": "modified_dark", "light": "modified_light" },
    "markdownImage": { "dark": "primary_dark", "light": "primary_light" },
    "markdownImageText": { "dark": "modified_dark", "light": "modified_light" },
    "markdownCodeBlock": { "dark": "text_dark", "light": "text_light" },
    "syntaxComment": { "dark": "syntax_comment_dark", "light": "syntax_comment_light" },
    "syntaxKeyword": { "dark": "syntax_keyword_dark", "light": "syntax_keyword_light" },
    "syntaxFunction": { "dark": "syntax_function_dark", "light": "syntax_function_light" },
    "syntaxVariable": { "dark": "syntax_variable_dark", "light": "syntax_variable_light" },
    "syntaxString": { "dark": "syntax_string_dark", "light": "syntax_string_light" },
    "syntaxNumber": { "dark": "syntax_number_dark", "light": "syntax_number_light" },
    "syntaxType": { "dark": "syntax_type_dark", "light": "syntax_type_light" },
    "syntaxOperator": { "dark": "syntax_operator_dark", "light": "syntax_operator_light" },
    "syntaxPunctuation": { "dark": "syntax_punctuation_dark", "light": "syntax_punctuation_light" }
  }
}
