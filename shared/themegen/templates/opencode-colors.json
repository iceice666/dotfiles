{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "primary_dark": "{{color.dark.primary}}",
    "primary_light": "{{color.light.primary}}",
    "on_primary_dark": "{{color.dark.on_primary}}",
    "on_primary_light": "{{color.light.on_primary}}",
    "secondary_dark": "{{color.dark.secondary}}",
    "secondary_light": "{{color.light.secondary}}",
    "on_secondary_dark": "{{color.dark.on_secondary}}",
    "on_secondary_light": "{{color.light.on_secondary}}",
    "surface_dark": "{{color.dark.surface}}",
    "surface_light": "{{color.light.surface}}",
    "on_surface_dark": "{{color.dark.on_surface}}",
    "on_surface_light": "{{color.light.on_surface}}",
    "surface_variant_dark": "{{color.dark.surface_variant}}",
    "surface_variant_light": "{{color.light.surface_variant}}",
    "on_surface_variant_dark": "{{color.dark.on_surface_variant}}",
    "on_surface_variant_light": "{{color.light.on_surface_variant}}",
    "background_dark": "{{color.dark.background}}",
    "background_light": "{{color.light.background}}",
    "error_dark": "{{color.dark.error}}",
    "error_light": "{{color.light.error}}",
    "outline_dark": "{{color.dark.outline}}",
    "outline_light": "{{color.light.outline}}",
    "outline_variant_dark": "{{color.dark.outline_variant}}",
    "outline_variant_light": "{{color.light.outline_variant}}"
  },
  "theme": {
    "primary": { "dark": "primary_dark", "light": "primary_light" },
    "secondary": { "dark": "secondary_dark", "light": "secondary_light" },
    "accent": { "dark": "primary_dark", "light": "primary_light" },
    "error": { "dark": "error_dark", "light": "error_light" },
    "warning": { "dark": "secondary_dark", "light": "secondary_light" },
    "success": { "dark": "secondary_dark", "light": "secondary_light" },
    "info": { "dark": "primary_dark", "light": "primary_light" },
    "text": { "dark": "on_surface_dark", "light": "on_surface_light" },
    "textMuted": { "dark": "on_surface_variant_dark", "light": "on_surface_variant_light" },
    "background": { "dark": "background_dark", "light": "background_light" },
    "backgroundPanel": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "backgroundElement": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "border": { "dark": "outline_variant_dark", "light": "outline_variant_light" },
    "borderActive": { "dark": "outline_dark", "light": "outline_light" },
    "borderSubtle": { "dark": "outline_variant_dark", "light": "outline_variant_light" },
    "diffAdded": { "dark": "secondary_dark", "light": "secondary_light" },
    "diffRemoved": { "dark": "error_dark", "light": "error_light" },
    "diffContext": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffHunkHeader": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffHighlightAdded": { "dark": "secondary_dark", "light": "secondary_light" },
    "diffHighlightRemoved": { "dark": "error_dark", "light": "error_light" },
    "diffAddedBg": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffRemovedBg": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffContextBg": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffLineNumber": { "dark": "on_surface_variant_dark", "light": "on_surface_variant_light" },
    "diffAddedLineNumberBg": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "diffRemovedLineNumberBg": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "markdownText": { "dark": "on_surface_dark", "light": "on_surface_light" },
    "markdownHeading": { "dark": "primary_dark", "light": "primary_light" },
    "markdownLink": { "dark": "primary_dark", "light": "primary_light" },
    "markdownLinkText": { "dark": "secondary_dark", "light": "secondary_light" },
    "markdownCode": { "dark": "secondary_dark", "light": "secondary_light" },
    "markdownBlockQuote": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "markdownEmph": { "dark": "secondary_dark", "light": "secondary_light" },
    "markdownStrong": { "dark": "primary_dark", "light": "primary_light" },
    "markdownHorizontalRule": { "dark": "surface_variant_dark", "light": "surface_variant_light" },
    "markdownListItem": { "dark": "primary_dark", "light": "primary_light" },
    "markdownListEnumeration": { "dark": "secondary_dark", "light": "secondary_light" },
    "markdownImage": { "dark": "primary_dark", "light": "primary_light" },
    "markdownImageText": { "dark": "secondary_dark", "light": "secondary_light" },
    "markdownCodeBlock": { "dark": "on_surface_dark", "light": "on_surface_light" },
    "syntaxComment": { "dark": "on_surface_variant_dark", "light": "on_surface_variant_light" },
    "syntaxKeyword": { "dark": "primary_dark", "light": "primary_light" },
    "syntaxFunction": { "dark": "secondary_dark", "light": "secondary_light" },
    "syntaxVariable": { "dark": "on_surface_dark", "light": "on_surface_light" },
    "syntaxString": { "dark": "secondary_dark", "light": "secondary_light" },
    "syntaxNumber": { "dark": "secondary_dark", "light": "secondary_light" },
    "syntaxType": { "dark": "primary_dark", "light": "primary_light" },
    "syntaxOperator": { "dark": "on_surface_dark", "light": "on_surface_light" },
    "syntaxPunctuation": { "dark": "on_surface_variant_dark", "light": "on_surface_variant_light" }
  }
}
