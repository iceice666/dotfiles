{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "themegen",
  "author": "themegen",
  "themes": [
    {
      "name": "Themegen Dark",
      "appearance": "dark",
      "style": {
        "accents": [
          "{{color.dark.primary}}",
          "{{color.dark.secondary}}",
          "{{color.dark.tertiary}}"
        ],
        "background.appearance": "opaque",
        "border": "{{color.dark.outline_variant}}",
        "border.variant": "{{color.dark.outline}}",
        "border.focused": "{{color.dark.primary}}",
        "border.selected": "{{color.dark.primary}}",
        "border.transparent": "{{ color.dark.outline_variant | with_alpha(40) | to_hex() }}",
        "border.disabled": "{{ color.dark.outline_variant | with_alpha(60) | to_hex() }}",
        "elevated_surface.background": "{{color.dark.surface_container_high}}",
        "surface.background": "{{color.dark.surface_container}}",
        "background": "{{color.dark.background}}",
        "element.background": "{{color.dark.surface_container}}",
        "element.hover": "{{color.dark.surface_container_high}}",
        "element.active": "{{color.dark.surface_container_highest}}",
        "element.selected": "{{color.dark.secondary_container}}",
        "element.disabled": "{{color.dark.surface_variant}}",
        "drop_target.background": "{{ color.dark.primary_container | with_alpha(80) | to_hex() }}",
        "ghost_element.background": null,
        "ghost_element.hover": "{{ color.dark.surface_container | with_alpha(80) | to_hex() }}",
        "ghost_element.active": "{{color.dark.surface_container_high}}",
        "ghost_element.selected": "{{ color.dark.secondary_container | with_alpha(80) | to_hex() }}",
        "ghost_element.disabled": "{{ color.dark.surface_variant | with_alpha(60) | to_hex() }}",
        "text": "{{color.dark.on_surface}}",
        "text.muted": "{{color.dark.on_surface_variant}}",
        "text.placeholder": "{{ color.dark.on_surface_variant | with_alpha(99) | to_hex() }}",
        "text.disabled": "{{ color.dark.on_surface | with_alpha(60) | to_hex() }}",
        "text.accent": "{{color.dark.primary}}",
        "icon": "{{color.dark.on_surface}}",
        "icon.muted": "{{color.dark.on_surface_variant}}",
        "icon.disabled": "{{ color.dark.on_surface | with_alpha(60) | to_hex() }}",
        "icon.placeholder": "{{ color.dark.on_surface_variant | with_alpha(80) | to_hex() }}",
        "icon.accent": "{{color.dark.primary}}",
        "status_bar.background": "{{color.dark.surface}}",
        "title_bar.background": "{{color.dark.surface}}",
        "title_bar.inactive_background": "{{color.dark.surface_dim}}",
        "toolbar.background": "{{color.dark.surface_container_low}}",
        "tab_bar.background": "{{color.dark.surface_container}}",
        "tab.inactive_background": "{{color.dark.surface_container}}",
        "tab.active_background": "{{color.dark.surface_container_low}}",
        "search.match_background": "{{ color.dark.tertiary_container | with_alpha(80) | to_hex() }}",
        "panel.background": "{{color.dark.surface_container}}",
        "panel.focused_border": "{{color.dark.primary}}",
        "panel.indent_guide": "{{ color.dark.outline_variant | with_alpha(60) | to_hex() }}",
        "panel.indent_guide_active": "{{color.dark.outline}}",
        "panel.indent_guide_hover": "{{ color.dark.outline | with_alpha(80) | to_hex() }}",
        "pane.focused_border": "{{color.dark.primary}}",
        "pane_group.border": "{{color.dark.outline}}",
        "scrollbar.thumb.background": "{{ color.dark.on_surface_variant | with_alpha(80) | to_hex() }}",
        "scrollbar.thumb.hover_background": "{{ color.dark.on_surface_variant | with_alpha(c0) | to_hex() }}",
        "scrollbar.thumb.border": "{{ color.dark.outline_variant | with_alpha(40) | to_hex() }}",
        "scrollbar.track.background": "{{color.dark.surface_container}}",
        "scrollbar.track.border": "{{ color.dark.outline_variant | with_alpha(20) | to_hex() }}",
        "editor.foreground": "{{color.dark.on_surface}}",
        "editor.background": "{{color.dark.surface_container_low}}",
        "editor.gutter.background": "{{color.dark.surface_container_low}}",
        "editor.subheader.background": "{{color.dark.surface_container}}",
        "editor.indent_guide": "{{ color.dark.outline_variant | with_alpha(60) | to_hex() }}",
        "editor.indent_guide_active": "{{color.dark.outline}}",
        "editor.active_line.background": "{{ color.dark.surface_container_high | with_alpha(80) | to_hex() }}",
        "editor.highlighted_line.background": "{{ color.dark.surface_container_high | with_alpha(60) | to_hex() }}",
        "editor.line_number": "{{color.dark.on_surface_variant}}",
        "editor.active_line_number": "{{color.dark.primary}}",
        "editor.invisible": "{{ color.dark.outline_variant | with_alpha(80) | to_hex() }}",
        "editor.wrap_guide": "{{ color.dark.outline_variant | with_alpha(40) | to_hex() }}",
        "editor.active_wrap_guide": "{{ color.dark.outline | with_alpha(80) | to_hex() }}",
        "editor.document_highlight.bracket_background": "{{ color.dark.primary_container | with_alpha(60) | to_hex() }}",
        "editor.document_highlight.read_background": "{{ color.dark.primary_container | with_alpha(60) | to_hex() }}",
        "editor.document_highlight.write_background": "{{ color.dark.secondary_container | with_alpha(80) | to_hex() }}",
        "terminal.background": "{{color.dark.surface_container_low}}",
        "terminal.ansi.background": "{{color.dark.surface_container_low}}",
        "terminal.foreground": "{{color.dark.on_surface}}",
        "terminal.bright_foreground": "{{color.dark.on_surface}}",
        "terminal.dim_foreground": "{{color.dark.on_surface_variant}}",
        "terminal.ansi.black": "{{color.dark.surface_dim}}",
        "terminal.ansi.bright_black": "{{color.dark.surface_container_high}}",
        "terminal.ansi.dim_black": "{{color.dark.surface}}",
        "terminal.ansi.red": "{{base16.dark.base08}}",
        "terminal.ansi.bright_red": "{{base16.dark.base08}}",
        "terminal.ansi.dim_red": "{{ base16.dark.base08 | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.green": "{{base16.dark.base0B}}",
        "terminal.ansi.bright_green": "{{base16.dark.base0B}}",
        "terminal.ansi.dim_green": "{{ base16.dark.base0B | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.yellow": "{{base16.dark.base0A}}",
        "terminal.ansi.bright_yellow": "{{base16.dark.base0A}}",
        "terminal.ansi.dim_yellow": "{{ base16.dark.base0A | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.blue": "{{base16.dark.base0D}}",
        "terminal.ansi.bright_blue": "{{base16.dark.base0D}}",
        "terminal.ansi.dim_blue": "{{ base16.dark.base0D | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.magenta": "{{base16.dark.base0E}}",
        "terminal.ansi.bright_magenta": "{{base16.dark.base0E}}",
        "terminal.ansi.dim_magenta": "{{ base16.dark.base0E | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.cyan": "{{base16.dark.base0C}}",
        "terminal.ansi.bright_cyan": "{{base16.dark.base0C}}",
        "terminal.ansi.dim_cyan": "{{ base16.dark.base0C | mix(color.dark.surface_container_low, 0.35) | to_hex() }}",
        "terminal.ansi.white": "{{color.dark.on_surface}}",
        "terminal.ansi.bright_white": "{{color.dark.on_surface}}",
        "terminal.ansi.dim_white": "{{color.dark.on_surface_variant}}",
        "link_text.hover": "{{color.dark.primary}}",
        "conflict": "{{color.dark.error}}",
        "conflict.background": "{{ color.dark.error_container | with_alpha(80) | to_hex() }}",
        "conflict.border": "{{color.dark.on_error_container}}",
        "created": "{{color.dark.tertiary}}",
        "created.background": "{{ color.dark.tertiary_container | with_alpha(80) | to_hex() }}",
        "created.border": "{{color.dark.on_tertiary_container}}",
        "deleted": "{{color.dark.error}}",
        "deleted.background": "{{ color.dark.error_container | with_alpha(80) | to_hex() }}",
        "deleted.border": "{{color.dark.on_error_container}}",
        "error": "{{color.dark.error}}",
        "error.background": "{{color.dark.error_container}}",
        "error.border": "{{color.dark.on_error_container}}",
        "hidden": "{{color.dark.outline_variant}}",
        "hidden.background": "{{ color.dark.surface_variant | with_alpha(40) | to_hex() }}",
        "hidden.border": "{{ color.dark.outline_variant | with_alpha(60) | to_hex() }}",
        "hint": "{{color.dark.primary}}",
        "hint.background": "{{ color.dark.primary_container | with_alpha(80) | to_hex() }}",
        "hint.border": "{{color.dark.on_primary_container}}",
        "ignored": "{{ color.dark.on_surface_variant | with_alpha(60) | to_hex() }}",
        "ignored.background": "{{ color.dark.surface_variant | with_alpha(40) | to_hex() }}",
        "ignored.border": "{{ color.dark.outline_variant | with_alpha(40) | to_hex() }}",
        "info": "{{color.dark.primary}}",
        "info.background": "{{ color.dark.primary_container | with_alpha(80) | to_hex() }}",
        "info.border": "{{color.dark.on_primary_container}}",
        "modified": "{{color.dark.secondary}}",
        "modified.background": "{{ color.dark.secondary_container | with_alpha(80) | to_hex() }}",
        "modified.border": "{{color.dark.on_secondary_container}}",
        "predictive": "{{ color.dark.on_surface_variant | with_alpha(80) | to_hex() }}",
        "predictive.border": "{{color.dark.outline}}",
        "predictive.background": "{{ color.dark.surface_container_highest | with_alpha(80) | to_hex() }}",
        "renamed": "{{color.dark.secondary}}",
        "renamed.border": "{{color.dark.on_secondary_container}}",
        "renamed.background": "{{ color.dark.secondary_container | with_alpha(80) | to_hex() }}",
        "success": "{{color.dark.tertiary}}",
        "success.background": "{{ color.dark.tertiary_container | with_alpha(80) | to_hex() }}",
        "success.border": "{{color.dark.on_tertiary_container}}",
        "unreachable": "{{ color.dark.on_surface_variant | with_alpha(60) | to_hex() }}",
        "unreachable.background": "{{ color.dark.surface_variant | with_alpha(40) | to_hex() }}",
        "unreachable.border": "{{ color.dark.outline_variant | with_alpha(60) | to_hex() }}",
        "warning": "{{color.dark.tertiary_fixed_dim}}",
        "warning.background": "{{ color.dark.tertiary_container | with_alpha(80) | to_hex() }}",
        "warning.border": "{{color.dark.on_tertiary_container}}",
        "players": [
          {
            "cursor": "{{color.dark.primary}}",
            "background": "{{ color.dark.primary_container | with_alpha(80) | to_hex() }}",
            "selection": "{{ color.dark.primary_container | with_alpha(60) | to_hex() }}"
          },
          {
            "cursor": "{{color.dark.secondary}}",
            "background": "{{ color.dark.secondary_container | with_alpha(80) | to_hex() }}",
            "selection": "{{ color.dark.secondary_container | with_alpha(60) | to_hex() }}"
          }
        ],
        "syntax": {
          "boolean": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "comment": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.08) | lightness(0.66) | readable(color.dark.surface_container_low, 3.2) | to_hex()}}",
            "font_style": "italic",
            "font_weight": null
          },
          "comment.doc": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.08) | lightness(0.66) | readable(color.dark.surface_container_low, 3.2) | to_hex()}}",
            "font_style": "italic",
            "font_weight": null
          },
          "constant": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "constructor": {
            "color": "{{source.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "emphasis": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": "italic",
            "font_weight": null
          },
          "emphasis.strong": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": 700
          },
          "function": {
            "color": "{{source.color | to_oklch() | rotate(-80) | chroma(0.12) | lightness(0.72) | readable(color.dark.surface_container_low, 3.2) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "keyword": {
            "color": "{{source.color | to_oklch() | rotate(-52) | chroma(0.16) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "number": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "operator": {
            "color": "{{color.dark.on_surface}}",
            "font_style": null,
            "font_weight": null
          },
          "property": {
            "color": "{{source.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation": {
            "color": "{{color.dark.on_surface_variant}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.bracket": {
            "color": "{{color.dark.on_surface}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.delimiter": {
            "color": "{{color.dark.on_surface_variant}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.list_marker": {
            "color": "{{color.dark.on_surface_variant}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.special": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "string": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.2) | lightness(0.79) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "string.escape": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.84) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "string.regex": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.26) | lightness(0.83) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "string.special": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.84) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "string.special.symbol": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.84) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "tag": {
            "color": "{{source.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "text.literal": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.2) | lightness(0.79) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "type": {
            "color": "{{source.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "variable": {
            "color": "{{source.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "variable.special": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "attribute": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "embedded": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.2) | lightness(0.79) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "enum": {
            "color": "{{source.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "hint": {
            "color": "{{color.dark.primary}}",
            "font_style": null,
            "font_weight": null
          },
          "label": {
            "color": "{{source.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "link_text": {
            "color": "{{color.dark.primary}}",
            "font_style": null,
            "font_weight": null
          },
          "link_uri": {
            "color": "{{source.color | to_oklch() | rotate(145) | chroma(0.24) | lightness(0.84) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "namespace": {
            "color": "{{source.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "predictive": {
            "color": "{{ color.dark.on_surface_variant | with_alpha(80) | to_hex() }}",
            "font_style": null,
            "font_weight": null
          },
          "preproc": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "primary": {
            "color": "{{color.dark.on_surface}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.markup": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "selector": {
            "color": "{{source.color | to_oklch() | rotate(18) | chroma(0.14) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "selector.pseudo": {
            "color": "{{source.color | to_oklch() | chroma(0.18) | lightness(0.78) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "title": {
            "color": "{{source.color | to_oklch() | rotate(170) | chroma(0.1) | lightness(0.74) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          },
          "variant": {
            "color": "{{source.color | to_oklch() | rotate(-32) | chroma(0.16) | lightness(0.8) | readable(color.dark.surface_container_low, 4.5) | to_hex()}}",
            "font_style": null,
            "font_weight": null
          }
        }
      }
    },
    {
      "name": "Themegen Light",
      "appearance": "light",
      "style": {
        "accents": [
          "{{color.light.primary}}",
          "{{color.light.secondary}}",
          "{{color.light.tertiary}}"
        ],
        "background.appearance": "opaque",
        "border": "{{color.light.outline_variant}}",
        "border.variant": "{{color.light.outline}}",
        "border.focused": "{{color.light.primary}}",
        "border.selected": "{{color.light.primary}}",
        "border.transparent": "{{ color.light.outline_variant | with_alpha(40) | to_hex() }}",
        "border.disabled": "{{ color.light.outline_variant | with_alpha(60) | to_hex() }}",
        "elevated_surface.background": "{{color.light.surface_container_high}}",
        "surface.background": "{{color.light.surface_container}}",
        "background": "{{color.light.background}}",
        "element.background": "{{color.light.surface_container}}",
        "element.hover": "{{color.light.surface_container_high}}",
        "element.active": "{{color.light.surface_container_highest}}",
        "element.selected": "{{color.light.secondary_container}}",
        "element.disabled": "{{color.light.surface_variant}}",
        "drop_target.background": "{{ color.light.primary_container | with_alpha(80) | to_hex() }}",
        "ghost_element.background": null,
        "ghost_element.hover": "{{ color.light.surface_container | with_alpha(80) | to_hex() }}",
        "ghost_element.active": "{{color.light.surface_container_high}}",
        "ghost_element.selected": "{{ color.light.secondary_container | with_alpha(80) | to_hex() }}",
        "ghost_element.disabled": "{{ color.light.surface_variant | with_alpha(60) | to_hex() }}",
