{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "permissions": {
    "deny": [
      "Read(//**/.env)",
      "Read(//**/.env.*)",
      "Read(//**/secrets/**)",
      "Read(//**/.ssh/**)",
      "Read(//**/.gnupg/**)",
      "Read(//**/.aws/credentials)",
      "Read(//**/.config/sops/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git push --force*)",
      "Bash(gh pr merge *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(cargo publish *)",
      "Bash(sudo *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(docker system prune *)"
    ],
    "defaultMode": "acceptEdits",
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "viewMode": "focus",
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "*.githubusercontent.com",
        "crates.io",
        "*.crates.io",
        "static.crates.io",
        "index.crates.io",
        "registry.npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "*.pythonhosted.org",
        "cache.nixos.org",
        "releases.nixos.org",
        "*.nixos.org"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.cache",
        "~/.cargo",
        "~/.npm",
        "~/.pnpm-store",
        "~/Library/Caches",
        "/tmp",
        "/var/tmp"
      ]
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "stable",
  "tui": "fullscreen",
  "prefersReducedMotion": true,
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false,
  "agentPushNotifEnabled": true,
  "advisorModel": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "timeout 300 true || echo 'long-running cmd: add --timeout'"
          }
        ]
      }
    ]
  }
}
