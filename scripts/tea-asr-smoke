#!/usr/bin/env bash
set -euo pipefail

base_url="${TEA_ASR_BASE_URL:-http://127.0.0.1:19000}"
timeout="${TEA_ASR_SMOKE_TIMEOUT:-1800}"
deadline=$((SECONDS + timeout))

echo "Waiting for $base_url/health"
while true; do
    if curl -fsS --max-time 10 -o /dev/null "$base_url/health" 2>/dev/null; then
        echo "ready"
        exit 0
    fi

    if ((SECONDS >= deadline)); then
        echo "TEA-ASR 1.1 mini did not become ready within ${timeout}s" >&2
        exit 1
    fi
    sleep 10
done
