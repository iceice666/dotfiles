#!/usr/bin/env bash
set -euo pipefail

sops_secret_temp_files=()
cleanup() {
  local file
  for file in "${sops_secret_temp_files[@]}"; do
    rm -f "$file"
  done
}
trap cleanup EXIT

usage() {
  cat >&2 <<'USAGE'
Usage:
  scripts/sops-secret encrypt <secret> [plaintext]
  scripts/sops-secret decrypt <secret> [output]
  scripts/sops-secret edit <secret>
USAGE
}

run_ssh_to_age() {
  if command -v ssh-to-age >/dev/null 2>&1; then
    ssh-to-age "$@"
    return 0
  fi

  if command -v nix >/dev/null 2>&1; then
    nix shell nixpkgs#ssh-to-age -c ssh-to-age "$@"
    return 0
  fi

  echo "ssh-to-age is required to derive a sops age identity from an SSH key." >&2
  exit 1
}

derive_age_key_file() {
  local ssh_key=$1
  local age_key

  age_key=$(mktemp "${TMPDIR:-/tmp}/sops-age-key.XXXXXX")
  sops_secret_temp_files+=("$age_key")

  chmod 600 "$age_key"
  if ! run_ssh_to_age -private-key -i "$ssh_key" -o "$age_key"; then
    echo "Failed to derive age identity from SSH key: $ssh_key" >&2
    exit 1
  fi

  SOPS_AGE_KEY_FILE="$age_key"
  export SOPS_AGE_KEY_FILE
}

identity_file() {
  local secret=$1

  if [[ -n "${SOPS_AGE_KEY_FILE:-}" || -n "${SOPS_AGE_KEY:-}" ]]; then
    return 0
  fi

  local xdg_key="$HOME/.config/sops/age/keys.txt"
  local darwin_key="$HOME/Library/Application Support/sops/age/keys.txt"
  local nixos_key="/var/lib/sops-nix/key.txt"

  local -a age_candidates
  if [[ "$secret" == sensitive/shared/* ]]; then
    age_candidates=(
      "$xdg_key"
      "$darwin_key"
      "$nixos_key"
    )
  else
    age_candidates=(
      "$nixos_key"
      "$xdg_key"
      "$darwin_key"
    )
  fi

  local candidate
  for candidate in "${age_candidates[@]}"; do
    if [[ -f "$candidate" ]]; then
      SOPS_AGE_KEY_FILE="$candidate"
      export SOPS_AGE_KEY_FILE
      return 0
    fi
  done

  local -a ssh_candidates=()
  if [[ -n "${SOPS_SSH_KEY_FILE:-}" ]]; then
    ssh_candidates+=("$SOPS_SSH_KEY_FILE")
  fi
  ssh_candidates+=("$HOME/.ssh/id_ed25519")

  for candidate in "${ssh_candidates[@]}"; do
    if [[ -f "$candidate" ]]; then
      derive_age_key_file "$candidate"
      return 0
    fi
  done

  cat >&2 <<EOF
No age identity or SSH key found for sops.

sops-nix derives age identities from SSH keys at activation time. This helper does
the same for local secret editing by converting an SSH key from:
  - SOPS_SSH_KEY_FILE
  - ~/.ssh/id_ed25519

You can also set SOPS_AGE_KEY_FILE to an existing age identity file, or create one
in a default location:
  - /var/lib/sops-nix/key.txt
  - ~/.config/sops/age/keys.txt
  - ~/Library/Application Support/sops/age/keys.txt
EOF
  exit 1
}

encrypt_secret() {
  local secret=$1 plaintext=${2:-}
  identity_file "$secret"

  case "$secret" in
    *.yaml|*.yml|*.json|*.env|*.ini)
      if [[ -n "$plaintext" ]]; then
        sops encrypt --output "$secret" "$plaintext"
      else
        sops encrypt --in-place "$secret"
      fi
      ;;
    *.key|*.pem)
      if [[ -n "$plaintext" ]]; then
        sops encrypt --input-type binary --output-type binary --output "$secret" "$plaintext"
      else
        sops encrypt --input-type binary --output-type binary --in-place "$secret"
      fi
      ;;
    *)
      echo "Unsupported secret file type: $secret" >&2
      exit 1
      ;;
  esac
}

decrypt_secret() {
  local secret=$1 output=${2:-}
  identity_file "$secret"

  if [[ -n "$output" && "$output" == "$secret" ]]; then
    echo "Refusing to decrypt '$secret' over itself. Use a different output path or 'just secret-edit $secret'." >&2
    exit 1
  fi

  case "$secret" in
    *.yaml|*.yml|*.json|*.env|*.ini)
      if [[ -n "$output" ]]; then
        sops decrypt --output "$output" "$secret"
      else
        sops decrypt "$secret"
      fi
      ;;
    *.key|*.pem)
      if [[ -z "$output" ]]; then
        echo "Binary secrets require an output path: just secret-decrypt $secret /tmp/output" >&2
        exit 1
      fi
      sops decrypt --input-type binary --output-type binary --output "$output" "$secret"
      ;;
    *)
      echo "Unsupported secret file type: $secret" >&2
      exit 1
      ;;
  esac
}

edit_secret() {
  local secret=$1
  identity_file "$secret"
  export EDITOR="${EDITOR:-nvim}"

  case "$secret" in
    *.yaml|*.yml|*.json|*.env|*.ini|*.key|*.pem)
      sops "$secret"
      ;;
    *)
      echo "Unsupported secret file type: $secret" >&2
      exit 1
      ;;
  esac
}

command=${1:-}
case "$command" in
  encrypt)
    [[ $# -ge 2 && $# -le 3 ]] || { usage; exit 2; }
    encrypt_secret "$2" "${3:-}"
    ;;
  decrypt)
    [[ $# -ge 2 && $# -le 3 ]] || { usage; exit 2; }
    decrypt_secret "$2" "${3:-}"
    ;;
  edit)
    [[ $# -eq 2 ]] || { usage; exit 2; }
    edit_secret "$2"
    ;;
  *)
    usage
    exit 2
    ;;
esac
