#!/usr/bin/env bash
set -euo pipefail

# Wake homolab via Wake-on-LAN and wait for it to be ready.
# Sends the magic packet directly when on the home LAN, or relays it through
# the gateway over the tailnet when off-site.
#
# Environment variables (all optional, defaults match lib/homolab.nix):
#   HOMOLAB_MAC              NIC MAC address
#   HOMOLAB_TAILNET_IP       homolab tailnet IP
#   HOMOLAB_GATEWAY_TAILNET  gateway tailnet IP (for off-LAN relay)
#   HOMOLAB_LAN_GW           home LAN gateway (used for on-LAN detection)
#   HOMOLAB_LAN_BROADCAST    LAN broadcast address
#   HOMOLAB_LLM_PORT         llama-swap port
#   HOMOLAB_WAKE_MODE        "ssh" = wait for tailnet only; "llm" = also wait for /health
#   HOMOLAB_WAKE_TIMEOUT     seconds before giving up (default 120)

MAC="${HOMOLAB_MAC:-24:4b:fe:df:2d:45}"
TAILNET_HOST="${HOMOLAB_TAILNET_HOST:-homolab-linux}"
TAILNET_IP="${HOMOLAB_TAILNET_IP:-100.110.95.111}"
GATEWAY_TAILNET="${HOMOLAB_GATEWAY_TAILNET:-100.119.84.114}"
LAN_GW="${HOMOLAB_LAN_GW:-192.168.1.1}"
LAN_BROADCAST="${HOMOLAB_LAN_BROADCAST:-192.168.1.255}"
LLM_PORT="${HOMOLAB_LLM_PORT:-11434}"
MODE="${HOMOLAB_WAKE_MODE:-llm}"
WAKE_TIMEOUT="${HOMOLAB_WAKE_TIMEOUT:-120}"

die() { echo "homolab-wake: $*" >&2; exit 1; }

echo "==> waking homolab ($MAC)"

# Check if we're on the home LAN by probing the local gateway.
if ping -c1 "$LAN_GW" >/dev/null 2>&1; then
    echo "==> on home LAN, sending magic packet directly"
    wakeonlan -i "$LAN_BROADCAST" "$MAC"
else
    echo "==> off home LAN, relaying via gateway ($GATEWAY_TAILNET)"
    ssh -o ConnectTimeout=10 root@"$GATEWAY_TAILNET" /root/.local/bin/homolab-wake ||
        die "gateway relay failed; ensure /root/.local/bin/homolab-wake is deployed and gateway is reachable"
fi

# Poll for tailnet reachability (host-up signal).
echo "==> waiting for homolab on tailnet (timeout ${WAKE_TIMEOUT}s)"
deadline=$((SECONDS + WAKE_TIMEOUT))
until tailscale ping --timeout=3s "$TAILNET_HOST" >/dev/null 2>&1; do
    [ "$SECONDS" -lt "$deadline" ] || die "timed out waiting for homolab on tailnet after ${WAKE_TIMEOUT}s"
    sleep 2
done
echo "==> homolab reachable on tailnet"

# Optionally wait for the LLM /health endpoint.
if [ "$MODE" = "llm" ]; then
    echo "==> waiting for LLM /health at $TAILNET_IP:$LLM_PORT"
    health_url="http://$TAILNET_IP:$LLM_PORT/health"
    until curl -fsS --max-time 5 "$health_url" >/dev/null 2>&1; do
        [ "$SECONDS" -lt "$deadline" ] || die "timed out waiting for LLM /health"
        sleep 3
    done
    echo "==> LLM ready: $health_url"
fi

echo "==> homolab is up"
