#!/usr/bin/env python3
"""Update pkgs/ Nix derivations to their latest GitHub releases.

Usage:
    scripts/update-pkgs [--dry-run] [pkg-name ...]

Without pkg-name arguments, checks all known packages. Requires gh CLI logged in.
"""

import base64
import hashlib
import json
import re
import subprocess
import sys
import urllib.request
from concurrent.futures import ThreadPoolExecutor, as_completed
from dataclasses import dataclass, field
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
PKGS_DIR = REPO_ROOT / "pkgs"
HASH_WORKERS = 8


# ── GitHub ───────────────────────────────────────────────────────────────────────

def gh_get(path: str):
    result = subprocess.run(
        ["gh", "api", path],
        capture_output=True, text=True, check=True,
    )
    return json.loads(result.stdout)


def latest_release(repo: str, tag_prefix: str) -> tuple[str, str]:
    """Return (tag, version). Scans /releases for non-standard prefixes."""
    if tag_prefix not in ("v", ""):
        releases = gh_get(f"/repos/{repo}/releases?per_page=30")
        tag = next(
            r["tag_name"] for r in releases
            if r["tag_name"].startswith(tag_prefix)
            and not r["draft"] and not r["prerelease"]
        )
    else:
        tag = gh_get(f"/repos/{repo}/releases/latest")["tag_name"]
    return tag, tag[len(tag_prefix):]


# ── Hashing ──────────────────────────────────────────────────────────────────────

def sri_hash(url: str) -> str:
    """Fetch url and return its SRI sha256 hash."""
    req = urllib.request.Request(url, headers={"User-Agent": "update-pkgs/1.0"})
    with urllib.request.urlopen(req, timeout=300) as r:
        digest = hashlib.sha256(r.read()).digest()
    return "sha256-" + base64.b64encode(digest).decode()


# ── Nix file helpers ─────────────────────────────────────────────────────────────

def _expand(s: str, vars: dict) -> str:
    for k, v in vars.items():
        s = s.replace(f"${{{k}}}", v)
    return s


def nix_vars(content: str) -> dict:
    """Extract {version, tag?, ...} from a nix let block."""
    m = re.search(r'\bversion\s*=\s*"([^"]+)"', content)
    if not m:
        raise ValueError("version assignment not found")
    version = m.group(1)
    vars = {"version": version}
    # Expand any extra let-bindings that appear in URLs (e.g. codex `tag`)
    for mv in re.finditer(r'^\s{2}(\w+)\s*=\s*"([^"]+)";\s*$', content, re.MULTILINE):
        k, v = mv.group(1), mv.group(2)
        if k != "version":
            vars[k] = _expand(v, vars)
    return vars


def url_hash_pairs(content: str) -> list[tuple[str, str]]:
    """Return [(url_template, hash_value)] in document order."""
    return re.findall(
        r'url\s*=\s*"([^"]+)";\s*\n\s*hash\s*=\s*"(sha256-[^"]+)"',
        content,
    )


# ── Package manifest ─────────────────────────────────────────────────────────────

@dataclass
class Package:
    name: str
    repo: str
    tag_prefix: str = "v"
    # platform (or "all") → Python url template using {tag} and {version}
    platforms: dict = field(default_factory=dict)

    @property
    def nix_file(self) -> Path:
        return PKGS_DIR / self.name / "default.nix"


PACKAGES: list[Package] = [
    Package("zed-bin", "zed-industries/zed", platforms={
        "aarch64-darwin": "https://github.com/zed-industries/zed/releases/download/{tag}/Zed-aarch64.dmg",
        "x86_64-darwin":  "https://github.com/zed-industries/zed/releases/download/{tag}/Zed-x86_64.dmg",
        "x86_64-linux":   "https://github.com/zed-industries/zed/releases/download/{tag}/zed-linux-x86_64.tar.gz",
        "aarch64-linux":  "https://github.com/zed-industries/zed/releases/download/{tag}/zed-linux-aarch64.tar.gz",
    }),
    Package("claude-code-bin", "anthropics/claude-code", platforms={
        "aarch64-darwin": "https://github.com/anthropics/claude-code/releases/download/{tag}/claude-darwin-arm64.tar.gz",
        "x86_64-darwin":  "https://github.com/anthropics/claude-code/releases/download/{tag}/claude-darwin-x64.tar.gz",
        "aarch64-linux":  "https://github.com/anthropics/claude-code/releases/download/{tag}/claude-linux-arm64.tar.gz",
