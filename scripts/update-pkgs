# ── Core update logic ─────────────────────────────────────────────────────────────

def process(pkg: Package, dry_run: bool) -> dict:
    content = pkg.nix_file.read_text()
    vars = nix_vars(content)
    old_version = vars["version"]
    old_tag = pkg.tag_prefix + old_version

    new_tag, new_version = latest_release(pkg.repo, pkg.tag_prefix)

    if old_version == new_version:
        return {"status": "current", "version": old_version}

    # Map concrete old URLs → their current hashes from the nix file
    old_url_to_hash: dict[str, str] = {}
    for url_tmpl, hash_val in url_hash_pairs(content):
        old_url_to_hash[_expand(url_tmpl, vars)] = hash_val

    # Compute new hashes for each unique new URL in parallel
    unique_new_urls = list({
        tmpl.format(tag=new_tag, version=new_version)
        for tmpl in pkg.platforms.values()
    })
    new_url_hash: dict[str, str] = {}
    with ThreadPoolExecutor(max_workers=HASH_WORKERS) as pool:
        futures = {pool.submit(sri_hash, url): url for url in unique_new_urls}
        for future in as_completed(futures):
            new_url_hash[futures[future]] = future.result()

    # Build old_hash → new_hash replacement map via URL matching
    replacements: dict[str, str] = {}
    for tmpl in pkg.platforms.values():
        old_url = tmpl.format(tag=old_tag, version=old_version)
        new_url = tmpl.format(tag=new_tag, version=new_version)
        old_hash = old_url_to_hash.get(old_url)
        new_hash = new_url_hash.get(new_url)
        if old_hash and new_hash and old_hash != new_hash:
            replacements[old_hash] = new_hash

    if not dry_run:
        new_content = content.replace(
            f'version = "{old_version}"',
            f'version = "{new_version}"',
        )
        for old_h, new_h in replacements.items():
            new_content = new_content.replace(f'hash = "{old_h}"', f'hash = "{new_h}"')
        pkg.nix_file.write_text(new_content)

    return {"status": "updated", "from": old_version, "to": new_version}


# ── CLI ──────────────────────────────────────────────────────────────────────────

def main() -> None:
    argv = sys.argv[1:]
    dry_run = "--dry-run" in argv
    names = [a for a in argv if not a.startswith("--")]

    selected = [p for p in PACKAGES if not names or p.name in names]
    if not selected:
        print(f"No packages matched: {names}", file=sys.stderr)
        sys.exit(1)

    results: dict[str, dict] = {}
    with ThreadPoolExecutor(max_workers=min(len(selected), 10)) as pool:
        futures = {pool.submit(process, pkg, dry_run): pkg.name for pkg in selected}
        for future in as_completed(futures):
            name = futures[future]
            try:
                results[name] = future.result()
            except Exception as e:
                results[name] = {"status": "error", "reason": str(e)}

    updated = sorted((n, r) for n, r in results.items() if r["status"] == "updated")
    current = sorted((n, r) for n, r in results.items() if r["status"] == "current")
    errors  = sorted((n, r) for n, r in results.items() if r["status"] == "error")

    suffix = " (dry run)" if dry_run else ""
    for name, r in updated:
        print(f"✓ {name}: {r['from']} → {r['to']}{suffix}")
    for name, r in current:
        print(f"- {name}: {r['version']}")
    for name, r in errors:
        print(f"✗ {name}: {r['reason']}", file=sys.stderr)

    if errors:
        sys.exit(1)


if __name__ == "__main__":
    main()
