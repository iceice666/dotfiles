        "x86_64-linux":   "https://github.com/zen-browser/desktop/releases/download/{tag}/zen.linux-x86_64.tar.xz",
        "aarch64-linux":  "https://github.com/zen-browser/desktop/releases/download/{tag}/zen.linux-aarch64.tar.xz",
