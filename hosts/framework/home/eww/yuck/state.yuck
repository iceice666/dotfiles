(deflisten niri_state :initial "{\"groups\":[],\"outputs\":{}}" "@niriState@")
(defpoll media :interval "2s" :initial "" "@mediaStatus@")
(defpoll perf :interval "1s" :initial "{\"cpu\":\"--\",\"ram\":\"--\",\"gpu\":\"--\",\"up\":\"--\",\"down\":\"--\"}" "@perfStatus@")
(defpoll battery :interval "60s" :initial "{\"text\":\"--\",\"class\":\"island battery\",\"icon\":\"@batteryUnknown@\",\"color\":\"#e5e5e5\"}" "@batteryStatus@")
(defpoll audio :interval "2s" :initial "{\"speaker_value\":0,\"speaker_muted\":false,\"speaker_class\":\"audio-control speaker\",\"speaker_icon\":\"@speakerHigh@\",\"speaker_text\":\"Speaker --\",\"speaker_color\":\"#e5e5e5\",\"mic_value\":0,\"mic_muted\":false,\"mic_class\":\"audio-control mic\",\"mic_icon\":\"@micActive@\",\"mic_text\":\"Microphone --\",\"mic_color\":\"#e5e5e5\"}" "@audioStatus@")
(defpoll datetime :interval "30s" :initial "" "@datetimeStatus@")
(defpoll notifications :interval "5s" :initial "{\"count\":0,\"label\":\"0\",\"class\":\"island notifications\",\"color\":\"#e5e5e5\"}" "@notificationsStatus@")
