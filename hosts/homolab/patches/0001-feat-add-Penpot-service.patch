diff --git a/services/dev/penpot.nix b/services/dev/penpot.nix
new file mode 100644
index 0000000..522915d
--- /dev/null
+++ b/services/dev/penpot.nix
@@ -0,0 +1,229 @@
+{
+  config,
+  homolab,
+  pkgs,
+  ...
+}:
+
+let
+  penpotVersion = "2.14.5";
+  penpotBaseDir = "/mnt/storage/penpot";
+  penpotAssetsDir = "${penpotBaseDir}/assets";
+  penpotSecretDir = "/var/lib/penpot/secrets";
+  penpotRuntimeDir = "/run/penpot";
+  penpotNetwork = "penpot-static";
+  penpotSubnet = "10.91.0.0/24";
+  penpotGateway = "10.91.0.1";
+  valkeyIp = "10.91.0.11";
+  exporterIp = "10.91.0.12";
+  backendIp = "10.91.0.13";
+  frontendIp = "10.91.0.14";
+
+  commonEnvironment = {
+    PENPOT_FLAGS = "enable-smtp enable-prepl-server enable-mcp disable-registration";
+    PENPOT_HTTP_SERVER_MAX_BODY_SIZE = "367001600";
+    PENPOT_HTTP_SERVER_MAX_MULTIPART_BODY_SIZE = "367001600";
+    PENPOT_PUBLIC_URI = homolab.urls.penpot;
+  };
+in
+{
+  systemd.tmpfiles.rules = [
+    "d '${penpotBaseDir}' 0750 root root - -"
+    "d '${penpotAssetsDir}' 0750 root root - -"
+    "d '${penpotSecretDir}' 0700 root root - -"
+  ];
+
+  systemd.services = {
+    penpot-network = {
+      description = "Create the private Podman network for Penpot";
+      wantedBy = [ "multi-user.target" ];
+      after = [ "network-online.target" ];
+      wants = [ "network-online.target" ];
+
+      path = [ config.virtualisation.podman.package ];
+
+      script = ''
+        podman network exists ${penpotNetwork} \
+          || podman network create --disable-dns --subnet ${penpotSubnet} --gateway ${penpotGateway} ${penpotNetwork}
+      '';
+
+      serviceConfig = {
+        Type = "oneshot";
+        RemainAfterExit = true;
+      };
+    };
+
+    penpot-env = {
+      description = "Generate local Penpot environment files";
+      wantedBy = [ "multi-user.target" ];
+
+      path = [
+        pkgs.coreutils
+        pkgs.openssl
+      ];
+
+      script = ''
+        install -d -m 0700 ${penpotSecretDir} ${penpotRuntimeDir}
+
+        if [ ! -s ${penpotSecretDir}/secret-key ]; then
+          openssl rand -base64 64 > ${penpotSecretDir}/secret-key
+          chmod 0400 ${penpotSecretDir}/secret-key
+        fi
+
+        if [ ! -s ${penpotSecretDir}/postgres-password ]; then
+          openssl rand -base64 48 > ${penpotSecretDir}/postgres-password
+          chmod 0400 ${penpotSecretDir}/postgres-password
+        fi
+
+        secret_key="$(tr -d '\n' < ${penpotSecretDir}/secret-key)"
+        postgres_password="$(tr -d '\n' < ${penpotSecretDir}/postgres-password)"
+        smtp_password="$(tr -d '\n' < ${config.sops.secrets."penpot-smtp-password".path})"
+
+        umask 077
+        printf 'PENPOT_SECRET_KEY=%s\nPENPOT_DATABASE_PASSWORD=%s\nPENPOT_SMTP_PASSWORD=%s\n' \
+          "$secret_key" "$postgres_password" "$smtp_password" \
+          > ${penpotRuntimeDir}/backend.env
+      '';
+
+      serviceConfig = {
+        Type = "oneshot";
+        RemainAfterExit = true;
+      };
+    };
+
+    penpot-postgres-role = {
+      description = "Apply the Penpot password to the central PostgreSQL role";
+      after = [
+        "postgresql-setup.service"
+        "penpot-env.service"
+      ];
+      requires = [
+        "postgresql-setup.service"
+        "penpot-env.service"
+      ];
+
+      path = [
+        config.services.postgresql.package
+        pkgs.coreutils
+        pkgs.util-linux
+      ];
+
+      script = ''
+        postgres_password="$(tr -d '\n' < ${penpotSecretDir}/postgres-password)"
+        runuser -u postgres -- psql \
+          --dbname=postgres \
+          --command "ALTER ROLE penpot WITH LOGIN PASSWORD '$postgres_password';"
+      '';
+
+      serviceConfig = {
+        Type = "oneshot";
+        RemainAfterExit = true;
+      };
+    };
+
+    penpot-valkey = {
+      after = [ "penpot-network.service" ];
+      requires = [ "penpot-network.service" ];
+    };
+
+    penpot-exporter = {
+      after = [ "penpot-env.service" ];
+      requires = [ "penpot-env.service" ];
+    };
+
+    penpot-backend = {
+      after = [
+        "penpot-env.service"
+        "penpot-postgres-role.service"
+      ];
+      requires = [
+        "penpot-env.service"
+        "penpot-postgres-role.service"
+      ];
+      unitConfig.RequiresMountsFor = penpotAssetsDir;
+    };
+
+    penpot-frontend.unitConfig.RequiresMountsFor = penpotAssetsDir;
+  };
+
+  virtualisation.oci-containers = {
+    backend = "podman";
+
+    containers = {
+      penpot-valkey = {
+        serviceName = "penpot-valkey";
+        image = "docker.io/valkey/valkey:8.1";
+        cmd = [
+          "valkey-server"
+          "--maxmemory"
+          "128mb"
+          "--maxmemory-policy"
+          "volatile-lfu"
+        ];
+        networks = [ "${penpotNetwork}:ip=${valkeyIp}" ];
+        extraOptions = [
+          "--health-cmd=valkey-cli ping | grep PONG"
+          "--health-interval=1s"
+          "--health-timeout=3s"
+          "--health-retries=5"
+          "--health-start-period=3s"
+        ];
+      };
+
+      penpot-exporter = {
+        serviceName = "penpot-exporter";
+        image = "docker.io/penpotapp/exporter:${penpotVersion}";
+        dependsOn = [ "penpot-valkey" ];
+        environment = {
+          PENPOT_PUBLIC_URI = "http://${frontendIp}:8080";
+          PENPOT_REDIS_URI = "redis://${valkeyIp}/0";
+        };
+        environmentFiles = [ "${penpotRuntimeDir}/backend.env" ];
+        networks = [ "${penpotNetwork}:ip=${exporterIp}" ];
+      };
+
+      penpot-backend = {
+        serviceName = "penpot-backend";
+        image = "docker.io/penpotapp/backend:${penpotVersion}";
+        dependsOn = [ "penpot-valkey" ];
+        environment = commonEnvironment // {
+          PENPOT_DATABASE_URI = "postgresql://${penpotGateway}/penpot";
+          PENPOT_DATABASE_USERNAME = "penpot";
+          PENPOT_EXPORTER_URI = "http://${exporterIp}:6061";
+          PENPOT_OBJECTS_STORAGE_BACKEND = "fs";
+          PENPOT_OBJECTS_STORAGE_FS_DIRECTORY = "/opt/data/assets";
+          PENPOT_REDIS_URI = "redis://${valkeyIp}/0";
+          PENPOT_SMTP_DEFAULT_FROM = "Penpot <${homolab.contact.noReplyEmail}>";
+          PENPOT_SMTP_DEFAULT_REPLY_TO = "Penpot <${homolab.contact.noReplyEmail}>";
+          PENPOT_SMTP_HOST = "smtp.resend.com";
+          PENPOT_SMTP_PORT = "465";
+          PENPOT_SMTP_SSL = "true";
+          PENPOT_SMTP_TLS = "false";
+          PENPOT_SMTP_USERNAME = "resend";
+          PENPOT_TELEMETRY_ENABLED = "false";
+        };
+        environmentFiles = [ "${penpotRuntimeDir}/backend.env" ];
+        networks = [ "${penpotNetwork}:ip=${backendIp}" ];
+        volumes = [ "${penpotAssetsDir}:/opt/data/assets" ];
+      };
+
+      penpot-frontend = {
+        serviceName = "penpot-frontend";
+        image = "docker.io/penpotapp/frontend:${penpotVersion}";
+        dependsOn = [
+          "penpot-backend"
+          "penpot-exporter"
+        ];
+        environment = commonEnvironment;
+        networks = [ "${penpotNetwork}:ip=${frontendIp}" ];
+        ports = [ "127.0.0.1:${toString homolab.ports.penpot}:8080" ];
+        volumes = [ "${penpotAssetsDir}:/opt/data/assets" ];
+        extraOptions = [
+          "--add-host=penpot-backend:${backendIp}"
+          "--add-host=penpot-exporter:${exporterIp}"
+        ];
+      };
+    };
+  };
+
+}
